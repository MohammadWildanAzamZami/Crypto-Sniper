{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "web/frontend/dist",
  "functions": {
    "api/index.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/auto-screen", "schedule": "0 * * * *" }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" }
  ]
}
