# Salin ke .env lalu isi. JANGAN commit .env yang berisi key asli.

# Anthropic API key (dari https://console.anthropic.com/settings/keys).
# WAJIB agar /api/chat bisa menjawab.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Model (opsional). Pakai haiku untuk biaya lebih murah.
ANTHROPIC_MODEL=claude-fable-5

# Port backend.
PORT=8788

# Origin yang boleh memanggil (CORS). "*" untuk demo; di produksi isi domainmu,
# mis. https://situs-kamu.com
ALLOWED_ORIGIN=*

# Batas request /api/chat per menit per IP (lindungi saldo API-mu).
RATE_MAX=15
