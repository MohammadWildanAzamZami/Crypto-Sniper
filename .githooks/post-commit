#!/bin/sh
# post-commit — perbarui rekap jurnal otomatis tiap kali ada commit,
# lalu commit + push perubahannya. Dipasang via: git config core.hooksPath .githooks
#
# Marker [jurnal-auto] pada pesan commit dipakai untuk mencegah rekursi.

# 1) Jangan jalan lagi kalau commit terakhir adalah commit auto-jurnal.
last_msg=$(git log -1 --format=%s 2>/dev/null)
case "$last_msg" in
  *"[jurnal-auto]"*) exit 0 ;;
esac

# 2) Lewati saat merge/rebase sedang berlangsung.
git_dir=$(git rev-parse --git-dir 2>/dev/null)
if [ -f "$git_dir/MERGE_HEAD" ] || [ -d "$git_dir/rebase-merge" ] || [ -d "$git_dir/rebase-apply" ]; then
  exit 0
fi

# 3) Butuh node untuk generator.
command -v node >/dev/null 2>&1 || { echo "[jurnal] node tidak ada di PATH, lewati."; exit 0; }

root=$(git rev-parse --show-toplevel)
node "$root/scripts/update-jurnal.js" || exit 0

# 4) Commit + push hanya kalau file jurnal benar-benar berubah.
if [ -n "$(git status --porcelain -- docs/JURNAL-AUTO.md)" ]; then
  git add docs/JURNAL-AUTO.md
  git commit -m "docs(jurnal): auto-update rekap harian [jurnal-auto]" -- docs/JURNAL-AUTO.md >/dev/null 2>&1

  # Auto-push hanya di branch main. Foreground agar andal di Windows (proses
  # background sering dimatikan saat git selesai); kegagalan push (offline/auth)
  # tidak menggagalkan commit karena hook selalu exit 0.
  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
  if [ "$branch" = "main" ]; then
    git push origin main >/dev/null 2>&1 || echo "[jurnal] push gagal (offline?), akan dicoba lagi oleh task harian."
  fi
fi
exit 0
