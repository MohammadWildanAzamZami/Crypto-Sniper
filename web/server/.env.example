# Copy to .env and fill in. Never commit the real keys.

# Solscan Pro API key. Optional for the screener (it falls back to DexScreener),
# required for the raw /api/* explorer endpoints and holder enrichment.
SOLSCAN_API_KEY=your_solscan_pro_api_key

# Telegram alerting (optional). Without these, /api/screen still works; only the
# alert delivery is skipped. See README BAGIAN 1 for how to get these.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Upstash Redis (optional). Only needed when running multiple instances behind a
# load balancer, so they share the alerted-mints set (atomic Redis SADD dedupe).
# Without these the Radar falls back to a local file / in-memory store (fine for
# a single process). Create a free DB at https://console.upstash.com and copy the
# REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

PORT=8787
